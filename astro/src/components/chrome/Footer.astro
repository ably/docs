---
import Icon from '@ably/ui/core/Icon';

const leftLinks = [
  { label: 'Changelog', href: 'https://changelog.ably.com/' },
  { label: 'About Ably', href: 'https://ably.com/about' },
  { label: 'Blog', href: 'https://ably.com/blog' },
];

const rightLinks = [
  { label: 'Data protection', href: 'https://ably.com/data-protection' },
  { label: 'Privacy', href: 'https://ably.com/privacy' },
  { label: 'Legals', href: 'https://ably.com/legals' },
];

const social = [
  { icon: 'icon-social-x-mono', href: 'https://x.com/ablyrealtime', label: 'X' },
  { icon: 'icon-social-linkedin-mono', href: 'https://linkedin.com/company/ably-realtime', label: 'LinkedIn' },
  { icon: 'icon-social-github-mono', href: 'https://github.com/ably', label: 'GitHub' },
];
---

<footer class="border-t border-neutral-200 bg-neutral-50 mt-16">
  <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col md:flex-row gap-6 md:items-center text-sm text-neutral-800">
    <nav class="flex flex-wrap gap-x-5 gap-y-2">
      {leftLinks.map((l) => (
        <a href={l.href} class="hover:text-neutral-1300">{l.label}</a>
      ))}
    </nav>
    <div class="flex-1"></div>
    <nav class="flex flex-wrap gap-x-5 gap-y-2">
      {rightLinks.map((l) => (
        <a href={l.href} class="hover:text-neutral-1300">{l.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      {social.map((s) => (
        <a href={s.href} aria-label={s.label} class="text-neutral-700 hover:text-neutral-1300">
          <Icon name={s.icon} size="1rem" />
        </a>
      ))}
    </div>
  </div>
</footer>
