{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "src/**/*", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "src/*": ["../src/*"],
      "gatsby": ["src/shims/gatsby.tsx"],
      "@reach/router": ["src/shims/reach-router.tsx"]
    }
  }
}
