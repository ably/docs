---
import Icon from '@ably/ui/core/Icon';
import logoUrl from '@ably/ui/core/images/logo/ably-logo.svg?url';
import LanguageSelector from '../islands/LanguageSelector';

const navItems = [
  { label: 'Documentation', href: '/docs', active: true },
  { label: 'Examples', href: '/examples' },
];

// Phase 3 PoC: static header. The real Header.tsx pulls from
// gatsby's useStaticQuery + reach-router's useLocation — both are removed
// in this port. Sign-in/account affordance is a separate island (to come).
---

<header class="border-b border-neutral-200 bg-white sticky top-0 z-10">
  <div class="max-w-7xl mx-auto px-6 h-14 flex items-center gap-6">
    <a href="/" class="flex items-center gap-2 shrink-0">
      <img src={logoUrl} alt="Ably" class="h-6" />
      <span class="text-sm text-neutral-700 hidden sm:inline">Docs</span>
    </a>
    <nav class="flex items-center gap-1 text-sm">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`px-3 py-1.5 rounded transition-colors ${
            item.active
              ? 'text-neutral-1300 font-medium'
              : 'text-neutral-700 hover:text-neutral-1300'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex-1"></div>
    <LanguageSelector client:load />
    <a
      href="https://ably.com/support"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded text-sm text-neutral-700 hover:text-neutral-1300"
    >
      <Icon name="icon-gui-lifebuoy-outline" size="1rem" />
      Support
    </a>
    <a
      href="https://ably.com/login"
      class="px-3 py-1.5 rounded text-sm border border-neutral-300 hover:bg-neutral-50"
    >
      Sign in
    </a>
  </div>
</header>
