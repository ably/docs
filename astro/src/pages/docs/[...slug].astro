---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { mdxComponents } from '../../components/mdx';

export async function getStaticPaths() {
  // PoC slice: a handful of pages that exercise the tricky bits. Widening
  // this is Phase 5. Keep in sync with PLAN.md § "PoC page slice".
  // Must live inside getStaticPaths — Astro evaluates it in an isolated scope.
  // Astro's glob loader strips `/index` from IDs, so `chat/index.mdx`
  // becomes id `chat`.
  const POC_SLICE = new Set([
    'chat',
    'chat/setup',
    'chat/connect',
    'basics',
    'getting-started',
    'getting-started/javascript',
    'messages',
    'ai-transport',
    // Added in Phase 4 to exercise `<If lang=...>` gates end-to-end.
    'liveobjects',
  ]);

  const entries = await getCollection('docs', ({ id }) => POC_SLICE.has(id));
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, meta_description, meta_keywords, intro, languages } = entry.data;
---

<DocsLayout
  title={title}
  description={meta_description}
  keywords={meta_keywords}
  intro={intro}
  currentId={entry.id}
  languages={languages ?? undefined}
>
  <Content components={mdxComponents} />
</DocsLayout>
